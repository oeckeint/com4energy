# ==============================================================================
# RECORDS API - Environment Configuration Template
# ==============================================================================
#
# INSTRUCCIONES:
# 1. Copia este archivo como ".env" en la raíz del proyecto
# 2. Reemplaza los valores de ejemplo con tus configuraciones reales
# 3. NUNCA subas el archivo .env a Git (ya está en .gitignore)
#
# ==============================================================================

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# MySQL Database Connection
DB_URL_SGE=jdbc:mysql://localhost:3306/com4energy_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USER_SGE=root
DB_PASSWORD_SGE=tu_password_aqui

# Connection Pool Settings (Opcional - tiene valores por defecto)
# DB_POOL_SIZE=20
# DB_MIN_IDLE=5
# DB_CONNECTION_TIMEOUT=20000

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================

# Server Port (default: 8082)
SERVER_PORT=8082

# Application Name
APP_NAME=records-api

# Environment (development, staging, production)
ENVIRONMENT=development

# ==============================================================================
# LOGGING CONFIGURATION
# ==============================================================================

# Log Level (TRACE, DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Log to file (true/false)
LOG_TO_FILE=false

# Log file path
# LOG_FILE_PATH=/var/log/records-api/application.log

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================

# Allowed Origins (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# ==============================================================================
# RABBITMQ CONFIGURATION (FUTURO)
# ==============================================================================

# RabbitMQ Connection
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USERNAME=guest
# RABBITMQ_PASSWORD=guest
# RABBITMQ_VHOST=/

# Queue Names
# RABBITMQ_QUEUE_INPUT=medidas.input.queue
# RABBITMQ_QUEUE_PROCESS=medidas.process.queue
# RABBITMQ_QUEUE_DLQ=medidas.dlq.queue

# Exchange Name
# RABBITMQ_EXCHANGE=medidas.exchange

# ==============================================================================
# REDIS CONFIGURATION (FUTURO)
# ==============================================================================

# Redis Connection
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DATABASE=0

# Cache TTL (seconds)
# CACHE_TTL=300

# ==============================================================================
# SECURITY CONFIGURATION (FUTURO)
# ==============================================================================

# JWT Secret Key
# JWT_SECRET=tu_secreto_super_seguro_aqui_minimo_256_bits
# JWT_EXPIRATION=86400

# API Key for external services
# API_KEY_EXTERNAL=tu_api_key_aqui

# ==============================================================================
# MONITORING & OBSERVABILITY (FUTURO)
# ==============================================================================

# Actuator Endpoints
# ACTUATOR_ENABLED=true
# ACTUATOR_BASE_PATH=/actuator

# Prometheus Metrics
# PROMETHEUS_ENABLED=false

# ==============================================================================
# PERFORMANCE TUNING
# ==============================================================================

# Max Batch Size for bulk operations
# MAX_BATCH_SIZE=1000

# Cache TTL in seconds
# CACHE_TTL_SECONDS=60

# Query timeout in seconds
# QUERY_TIMEOUT=30

# ==============================================================================
# FEATURE FLAGS (FUTURO)
# ==============================================================================

# Enable/Disable features
# FEATURE_ASYNC_PROCESSING=false
# FEATURE_CACHE_ENABLED=true
# FEATURE_AUDIT_ENABLED=true
# FEATURE_VALIDATION_STRICT=true

# ==============================================================================
# EXTERNAL SERVICES (FUTURO)
# ==============================================================================

# External API endpoints
# EXTERNAL_SERVICE_URL=https://api.external.com
# EXTERNAL_SERVICE_TIMEOUT=5000

# ==============================================================================
# NOTES
# ==============================================================================
#
# - Todos los valores son ejemplos
# - Ajusta según tu entorno (development, staging, production)
# - Para producción, usa secretos más seguros
# - Considera usar un servicio de gestión de secretos (AWS Secrets Manager, etc)
#
# ==============================================================================

